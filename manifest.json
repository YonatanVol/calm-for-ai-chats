{
  "manifest_version": 3,
  "name": "Calm — Reading Mode for AI Chats",
  "version": "2.1.0",
  "description": "Distraction-free reading for ChatGPT and Gemini: hide the input, Zen mode, reading width, and more.",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://gemini.google.com/*"],
      "js": [
        "src/adapters.js",
        "src/state.js",
        "src/modes.js",
        "src/presets.js",
        "src/audio.js",
        "src/pomodoro.js",
        "src/ui.js",
        "src/core.js",
        "src/typeahead.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
