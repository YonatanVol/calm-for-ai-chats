{
  "manifest_version": 3,
  "name": "ChatGPT Input Toggle",
  "version": "1.0.0",
  "description": "Hide/show the ChatGPT input composer for distraction-free reading.",
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
